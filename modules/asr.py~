mport re
import time
from faster_whisper import WhisperModel


def clean_japanese_text(text: str) -> str:
    text = text.strip()
    text = re.sub(r"\s+", "", text)
    text = text.replace("。。", "。")
    text = text.replace("、、", "、")
    return text


